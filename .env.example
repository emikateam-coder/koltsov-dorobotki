BOT_TOKEN=000000000:AAA-your-token-here
WEB_APP_URL=https://your-mini-app.example.com
API_PORT=3001
API_ALLOWED_ORIGINS=https://your-mini-app.example.com,http://localhost:5173
VITE_API_URL=http://localhost:3001
DATABASE_PATH=./data/app.sqlite
# Telegram user IDs организаторов (через запятую). Только они могут создавать/редактировать события.
ORGANIZER_TELEGRAM_IDS=

# Google Sheets export (опционально). Если не заполнено — выгрузка отключена.
# 1) Создай сервис-аккаунт в Google Cloud Console, скачай JSON-ключ.
# 2) Создай Google-таблицу и расшарь её на email сервис-аккаунта (роль Editor).
# 3) ID таблицы — это часть URL между /d/ и /edit.
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=Registrations
# Можно указать путь к файлу JSON-ключа:
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json
# Либо положить сам JSON в одну строку (для прода/Railway/Render):
GOOGLE_SERVICE_ACCOUNT_JSON=
